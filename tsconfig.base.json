{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@dashboard-builder-nx/source"],
    "baseUrl": ".",
    "paths": {
      "@dashboard-builder-nx/ui": ["libs/ui/src/index.ts"],
      "@dashboard-builder-nx/datasources": ["libs/datasources/src/index.ts"]
    }
  }
}
